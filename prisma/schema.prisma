generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["alumno", "app_user", "core", "entrenador", "ubi"]
}

model Pais {
  id                Int                 @id @default(autoincrement()) @map("id")
  nombre            String              @map("nombre") @db.VarChar(50)
  entidadFederativa EntidadFederativa[]

  @@map("pais")
  @@schema("ubi")
}

model EntidadFederativa {
  id        BigInt      @id @default(autoincrement()) @map("id")
  nombre    String      @map("nombre") @db.VarChar(50)
  idPais    Int         @map("id_pais")
  pais      Pais        @relation(fields: [idPais], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "entidad_federativa_id_pais_foreign")
  municipio Municipio[]

  @@map("entidad_federativa")
  @@schema("ubi")
}

model Municipio {
  id                  BigInt            @id @default(autoincrement()) @map("id")
  nombre              String            @map("nombre") @db.VarChar(50)
  idEntidadFederativa BigInt            @map("id_entidad_federativa")
  localidad           Localidad[]
  entidadFederativa   EntidadFederativa @relation(fields: [idEntidadFederativa], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "municipio_id_entidad_federativa_foreign")

  @@map("municipio")
  @@schema("ubi")
}

model Localidad {
  id          BigInt       @id @default(autoincrement()) @map("id")
  nombre      String       @map("nombre") @db.VarChar(50)
  idMunicipio BigInt       @map("id_municipio")
  entrenador  Entrenador[]
  gimnasio    Gimnasio[]
  municipio   Municipio    @relation(fields: [idMunicipio], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "localidad_id_municipio_foreign")

  @@map("localidad")
  @@schema("ubi")
}

model RedesSociales {
  id                      Int                       @id @default(autoincrement()) @map("id")
  nombre                  String                    @map("nombre") @db.VarChar(50)
  entrenadorRedesSociales EntrenadorRedesSociales[]

  @@map("redes_sociales")
  @@schema("core")
}

model TipoSeccion {
  id                BigInt              @id @default(autoincrement()) @map("id")
  nombre            String              @unique @map("nombre") @db.VarChar(100)
  entrenadorSeccion EntrenadorSeccion[]

  @@map("tipo_seccion")
  @@schema("core")
}

model Categorias {
  id                   Int                    @id @default(autoincrement()) @map("id")
  nombre               String                 @map("nombre") @db.VarChar(50)
  entrenadorCategorias EntrenadorCategorias[]

  @@map("categorias")
  @@schema("core")
}

model Estado {
  id                  Int                   @id @default(autoincrement()) @map("id")
  nombre              String                @map("nombre") @db.VarChar(30)
  alumno              Alumno[]              @relation("estado_alumno")
  sesionEntrenamiento SesionEntrenamiento[] @relation("estado_sesion")
  entrenador          Entrenador[]          @relation("estado_entrenador")
  gimnasio            Gimnasio[]            @relation("estado_gimnasio")

  @@map("estado")
  @@schema("core")
}

model Musculo {
  id                            BigInt                          @id @default(autoincrement()) @map("id")
  nombre                        String                          @unique @map("nombre") @db.VarChar(100)
  createdAt                     DateTime                        @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                     DateTime                        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  ejercicioPersonalizadoMusculo EjercicioPersonalizadoMusculo[]
  ejercicioEstandarMusculo      EjercicioEstandarMusculo[]

  @@map("musculo")
  @@schema("core")
}

model Equipo {
  id                           BigInt                         @id @default(autoincrement()) @map("id")
  nombre                       String                         @unique @map("nombre") @db.VarChar(100)
  createdAt                    DateTime                       @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                    DateTime                       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  ejercicioPersonalizadoEquipo EjercicioPersonalizadoEquipo[]
  ejercicioEstandarEquipo      EjercicioEstandarEquipo[]

  @@map("equipo")
  @@schema("core")
}

model EjercicioEstandar {
  id                       BigInt                     @id @default(autoincrement()) @map("id")
  nombre                   String                     @map("nombre") @db.VarChar(150)
  descripcion              String?                    @map("descripcion")
  urlImagen                String?                    @map("url_imagen")
  createdAt                DateTime                   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  alumnoEjercicioPr        AlumnoEjercicioPr[]
  rutinaEjercicio          RutinaEjercicio[]
  sesionEjercicio          SesionEjercicio[]
  ejercicioEstandarEquipo  EjercicioEstandarEquipo[]
  ejercicioEstandarMusculo EjercicioEstandarMusculo[]

  @@map("ejercicio_estandar")
  @@schema("core")
}

model EjercicioEstandarMusculo {
  idEjercicioEstandar BigInt            @map("id_ejercicio_estandar")
  idMusculo           BigInt            @map("id_musculo")
  ejercicioEstandar   EjercicioEstandar @relation(fields: [idEjercicioEstandar], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ejercicio_estandar_musculo_id_ejercicio_estandar_foreign")
  musculo             Musculo           @relation(fields: [idMusculo], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ejercicio_estandar_musculo_id_musculo_foreign")

  @@id([idEjercicioEstandar, idMusculo])
  @@map("ejercicio_estandar_musculo")
  @@schema("core")
}

model DiaSemana {
  id              Int               @id @map("id") @db.SmallInt
  nombre          String            @unique @map("nombre") @db.VarChar(20)
  rutinaSemanaDia RutinaSemanaDia[]
  usuarioRutina   UsuarioRutina[]

  @@map("dia_semana")
  @@schema("core")
}

model EjercicioEstandarEquipo {
  idEjercicioEstandar BigInt            @map("id_ejercicio_estandar")
  idEquipo            BigInt            @map("id_equipo")
  ejercicioEstandar   EjercicioEstandar @relation(fields: [idEjercicioEstandar], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ejercicio_estandar_equipo_id_ejercicio_estandar_foreign")
  equipo              Equipo            @relation(fields: [idEquipo], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ejercicio_estandar_equipo_id_equipo_foreign")

  @@id([idEjercicioEstandar, idEquipo])
  @@map("ejercicio_estandar_equipo")
  @@schema("core")
}

model CategoriaRutina {
  id          Int      @id @default(autoincrement()) @map("id")
  nombre      String   @unique @map("nombre") @db.VarChar(100)
  descripcion String?  @map("descripcion")
  rutina      Rutina[]

  @@map("categoria_rutina")
  @@schema("core")
}

model Usuario {
  id                        String                      @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  idSexo                    Int                         @map("id_sexo") @db.SmallInt
  nombre                    String                      @map("nombre") @db.VarChar(20)
  apellidoPaterno           String                      @map("apellido_paterno") @db.VarChar(20)
  apellidoMaterno           String?                     @map("apellido_materno") @db.VarChar(20)
  correo                    String                      @unique @map("correo") @db.VarChar(60)
  hashedPassword            String                      @map("hashed_password") @db.VarChar(60)
  fechaNacimiento           DateTime                    @map("fecha_nacimiento") @db.Date
  fechaRegistro             DateTime                    @default(now()) @map("fecha_registro") @db.Date
  alumnoCreado              Alumno[]                    @relation("usuario_alumno_creado")
  alumno                    Alumno?                     @relation("usuario_alumno")
  alumnoActualizado         Alumno[]                    @relation("usuario_alumno_actualizado")
  alumnoEjercicioPr         AlumnoEjercicioPr[]         @relation("usuario_pr")
  historialCreado           AlumnoEntrenadorHistorial[] @relation("usuario_historial_creado")
  alumnoEntrenadorHistorial AlumnoEntrenadorHistorial[] @relation("usuario_historial")
  ejercicioPersonalizado    EjercicioPersonalizado[]    @relation("usuario_ejercicio_personalizado")
  rutina                    Rutina[]                    @relation("usuario_rutina")
  sesionCreada              SesionEntrenamiento[]       @relation("usuario_sesion_creada")
  sesionEntrenamiento       SesionEntrenamiento[]       @relation("usuario_sesion")
  sesionActualizada         SesionEntrenamiento[]       @relation("usuario_sesion_actualizada")
  sexo                      Sexo                        @relation(fields: [idSexo], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_id_sexo_foreign")
  usuarioMedicion           UsuarioMedicion[]
  usuarioRutinaAsignada     UsuarioRutina[]             @relation("usuario_rutina_asignada")
  usuarioRutinaCreada       UsuarioRutina[]             @relation("usuario_rutina_creada")
  usuarioRutina             UsuarioRutina[]             @relation("usuario_rutina_usuario")
  usuarioRutinaActualizada  UsuarioRutina[]             @relation("usuario_rutina_actualizada")
  entrenador                Entrenador?
  gimnasio                  Gimnasio[]                  @relation("usuario_gimnasio")

  @@map("usuario")
  @@schema("app_user")
}

model EjercicioPersonalizado {
  id                            BigInt                          @id @default(autoincrement()) @map("id")
  createdByUsuario              String                          @map("created_by_usuario") @db.Uuid
  nombre                        String                          @map("nombre") @db.VarChar(150)
  activa                        Boolean                         @default(true) @map("activa")
  descripcion                   String?                         @map("descripcion")
  urlImagen                     String?                         @map("url_imagen")
  linkInformacion               String?                         @map("link_informacion")
  createdAt                     DateTime                        @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                     DateTime                        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  alumnoEjercicioPr             AlumnoEjercicioPr[]
  usuario                       Usuario                         @relation("usuario_ejercicio_personalizado", fields: [createdByUsuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ejercicio_personalizado_created_by_usuario_foreign")
  ejercicioPersonalizadoEquipo  EjercicioPersonalizadoEquipo[]
  ejercicioPersonalizadoMusculo EjercicioPersonalizadoMusculo[]
  rutinaEjercicio               RutinaEjercicio[]
  sesionEjercicio               SesionEjercicio[]

  @@unique([createdByUsuario, nombre], map: "ejercicio_personalizado_nombre_usuario_unique")
  @@map("ejercicio_personalizado")
  @@schema("app_user")
}

model EjercicioPersonalizadoMusculo {
  idEjercicioPersonalizado BigInt                 @map("id_ejercicio_personalizado")
  idMusculo                BigInt                 @map("id_musculo")
  ejercicioPersonalizado   EjercicioPersonalizado @relation(fields: [idEjercicioPersonalizado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ej_per_mus_id_ej_per_fkey")
  musculo                  Musculo                @relation(fields: [idMusculo], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ej_per_mus_id_musculo_fkey")

  @@id([idEjercicioPersonalizado, idMusculo])
  @@map("ejercicio_personalizado_musculo")
  @@schema("app_user")
}

model EjercicioPersonalizadoEquipo {
  idEjercicioPersonalizado BigInt                 @map("id_ejercicio_personalizado")
  idEquipo                 BigInt                 @map("id_equipo")
  ejercicioPersonalizado   EjercicioPersonalizado @relation(fields: [idEjercicioPersonalizado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ej_per_eq_id_ej_per_fkey")
  equipo                   Equipo                 @relation(fields: [idEquipo], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ej_per_eq_id_equipo_fkey")

  @@id([idEjercicioPersonalizado, idEquipo])
  @@map("ejercicio_personalizado_equipo")
  @@schema("app_user")
}

model Rutina {
  id                  BigInt                @id @default(autoincrement()) @map("id")
  createdByUsuario    String                @map("created_by_usuario") @db.Uuid
  nombre              String                @map("nombre") @db.VarChar(100)
  descripcion         String?               @map("descripcion")
  activa              Boolean               @default(true) @map("activa")
  idCategoriaRutina   Int?                  @map("id_categoria_rutina")
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  usuario             Usuario               @relation("usuario_rutina", fields: [createdByUsuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rutina_created_by_usuario_foreign")
  categoriaRutina     CategoriaRutina?      @relation(fields: [idCategoriaRutina], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rutina_id_categoria_rutina_foreign")
  rutinaEjercicio     RutinaEjercicio[]
  rutinaSemanaDia     RutinaSemanaDia[]
  sesionEntrenamiento SesionEntrenamiento[]
  usuarioRutina       UsuarioRutina[]

  @@unique([createdByUsuario, nombre], map: "rutina_nombre_usuario_unique")
  @@map("rutina")
  @@schema("app_user")
}

model RutinaEjercicio {
  id                             BigInt                           @id @default(autoincrement()) @map("id")
  idRutina                       BigInt                           @map("id_rutina")
  idEjercicioEstandar            BigInt?                          @map("id_ejercicio_estandar")
  idEjercicioPersonalizado       BigInt?                          @map("id_ejercicio_personalizado")
  orden                          Int                              @map("orden")
  series                         Int                              @map("series")
  repeticiones                   Int                              @map("repeticiones")
  pesoObjetivo                   Decimal?                         @map("peso_objetivo") @db.Decimal(10, 2)
  notaEntrenador                 String?                          @map("nota_entrenador")
  linkApoyo                      String?                          @map("link_apoyo")
  ejercicioEstandar              EjercicioEstandar?               @relation(fields: [idEjercicioEstandar], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rutina_ejercicio_id_ejercicio_estandar_foreign")
  ejercicioPersonalizado         EjercicioPersonalizado?          @relation(fields: [idEjercicioPersonalizado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rutina_ejercicio_id_ejercicio_personalizado_foreign")
  rutina                         Rutina                           @relation(fields: [idRutina], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rutina_ejercicio_id_rutina_foreign")
  sesionEjercicio                SesionEjercicio[]
  usuarioRutinaEjercicioOverride UsuarioRutinaEjercicioOverride[]

  @@map("rutina_ejercicio")
  @@schema("app_user")
}

model RutinaSemanaDia {
  id          BigInt    @id @default(autoincrement()) @map("id")
  idRutina    BigInt    @map("id_rutina")
  idDiaSemana Int       @map("id_dia_semana") @db.SmallInt
  activa      Boolean   @default(true) @map("activa")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  diaSemana   DiaSemana @relation(fields: [idDiaSemana], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rutina_semana_dia_id_dia_semana_foreign")
  rutina      Rutina    @relation(fields: [idRutina], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rutina_semana_dia_id_rutina_foreign")

  @@unique([idRutina, idDiaSemana], map: "rutina_semana_dia_rutina_dia_unique")
  @@map("rutina_semana_dia")
  @@schema("app_user")
}

model UsuarioRutinaEjercicioOverride {
  id                BigInt          @id @default(autoincrement()) @map("id")
  idUsuarioRutina   BigInt          @map("id_usuario_rutina")
  idRutinaEjercicio BigInt          @map("id_rutina_ejercicio")
  series            Int?
  repeticiones      Int?
  pesoObjetivo      Decimal?        @map("peso_objetivo") @db.Decimal(10, 2)
  notaEntrenador    String?         @map("nota_entrenador")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  rutinaEjercicio   RutinaEjercicio @relation(fields: [idRutinaEjercicio], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usr_rut_ej_ovr_id_rut_ej_fkey")
  usuarioRutina     UsuarioRutina   @relation(fields: [idUsuarioRutina], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usr_rut_ej_ovr_id_usr_rut_fkey")

  @@unique([idUsuarioRutina, idRutinaEjercicio], map: "usuario_rutina_ejercicio_override_unique")
  @@unique([idUsuarioRutina, idRutinaEjercicio], map: "usuario_rutina_ejercicio_override_usuario_rutina_ejercicio_uniq")
  @@map("usuario_rutina_ejercicio_override")
  @@schema("app_user")
}

model UsuarioRutina {
  id                  BigInt                           @id @default(autoincrement()) @map("id")
  idUsuario           String                           @map("id_usuario") @db.Uuid
  idRutina            BigInt                           @map("id_rutina")
  idDiaSemana         Int                              @map("id_dia_semana") @db.SmallInt
  fechaInicio         DateTime                         @map("fecha_inicio") @db.Date
  fechaFin            DateTime?                        @map("fecha_fin") @db.Date
  activa              Boolean                          @default(true) @map("activa")
  asignadaPorUsuario  String                           @map("asignada_por_usuario") @db.Uuid
  motivoCambio        String?                          @map("motivo_cambio")
  createdAt           DateTime                         @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime                         @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  createdBy           String?                          @map("created_by") @db.Uuid
  updatedBy           String?                          @map("updated_by") @db.Uuid
  sesionEntrenamiento SesionEntrenamiento[]
  asignadaPor         Usuario                          @relation("usuario_rutina_asignada", fields: [asignadaPorUsuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_rutina_asignada_por_usuario_foreign")
  createdByUsuario    Usuario?                         @relation("usuario_rutina_creada", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_rutina_created_by_foreign")
  diaSemana           DiaSemana                        @relation(fields: [idDiaSemana], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_rutina_id_dia_semana_foreign")
  rutina              Rutina                           @relation(fields: [idRutina], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_rutina_id_rutina_foreign")
  usuario             Usuario                          @relation("usuario_rutina_usuario", fields: [idUsuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_rutina_id_usuario_foreign")
  updatedByUsuario    Usuario?                         @relation("usuario_rutina_actualizada", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_rutina_updated_by_foreign")
  override            UsuarioRutinaEjercicioOverride[]

  @@unique([idUsuario, idRutina, idDiaSemana, fechaInicio], map: "usuario_rutina_unique_asignacion")
  @@index([idUsuario, idDiaSemana], map: "usuario_rutina_usuario_dia_idx")
  @@map("usuario_rutina")
  @@schema("app_user")
}

model SesionEntrenamiento {
  id               BigInt            @id @default(autoincrement()) @map("id")
  idUsuario        String            @map("id_usuario") @db.Uuid
  idUsuarioRutina  BigInt?           @map("id_usuario_rutina")
  idRutina         BigInt            @map("id_rutina")
  fechaSesion      DateTime          @map("fecha_sesion") @db.Timestamp(0)
  idEstado         Int               @default(2) @map("id_estado")
  notasAlumno      String?           @map("notas_alumno")
  notasEntrenador  String?           @map("notas_entrenador")
  duracionMinutos  Int?              @map("duracion_minutos")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  createdBy        String?           @map("created_by") @db.Uuid
  updatedBy        String?           @map("updated_by") @db.Uuid
  sesionEjercicio  SesionEjercicio[]
  createdByUsuario Usuario?          @relation("usuario_sesion_creada", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sesion_entrenamiento_created_by_foreign")
  estado           Estado            @relation("estado_sesion", fields: [idEstado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sesion_entrenamiento_id_estado_foreign")
  rutina           Rutina            @relation(fields: [idRutina], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sesion_entrenamiento_id_rutina_foreign")
  usuario          Usuario           @relation("usuario_sesion", fields: [idUsuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sesion_entrenamiento_id_usuario_foreign")
  usuarioRutina    UsuarioRutina?    @relation(fields: [idUsuarioRutina], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sesion_entrenamiento_id_usuario_rutina_foreign")
  updatedByUsuario Usuario?          @relation("usuario_sesion_actualizada", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sesion_entrenamiento_updated_by_foreign")

  @@map("sesion_entrenamiento")
  @@schema("app_user")
}

model UsuarioMedicion {
  id               BigInt   @id @default(autoincrement()) @map("id")
  idUsuario        String   @map("id_usuario") @db.Uuid
  fechaMedicion    DateTime @map("fecha_medicion") @db.Date
  pesoKg           Decimal? @map("peso_kg") @db.Decimal(6, 2)
  estaturaCm       Decimal? @map("estatura_cm") @db.Decimal(5, 2)
  grasaCorporalPct Decimal? @map("grasa_corporal_pct") @db.Decimal(5, 2)
  cinturaCm        Decimal? @map("cintura_cm") @db.Decimal(5, 2)
  caderaCm         Decimal? @map("cadera_cm") @db.Decimal(5, 2)
  pechoCm          Decimal? @map("pecho_cm") @db.Decimal(5, 2)
  brazoCm          Decimal? @map("brazo_cm") @db.Decimal(5, 2)
  piernaCm         Decimal? @map("pierna_cm") @db.Decimal(5, 2)
  nota             String?  @map("nota")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  usuario          Usuario  @relation(fields: [idUsuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_medicion_id_usuario_foreign")

  @@unique([idUsuario, fechaMedicion], map: "usuario_medicion_usuario_fecha_unique")
  @@map("usuario_medicion")
  @@schema("app_user")
}

model SesionEjercicio {
  id                       BigInt                  @id @default(autoincrement()) @map("id")
  idSesionEntrenamiento    BigInt                  @map("id_sesion_entrenamiento")
  idRutinaEjercicio        BigInt?                 @map("id_rutina_ejercicio")
  idEjercicioEstandar      BigInt?                 @map("id_ejercicio_estandar")
  idEjercicioPersonalizado BigInt?                 @map("id_ejercicio_personalizado")
  orden                    Int                     @map("orden")
  nota                     String?                 @map("nota")
  createdAt                DateTime                @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  ejercicioEstandar        EjercicioEstandar?      @relation(fields: [idEjercicioEstandar], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sesion_ejercicio_id_ejercicio_estandar_foreign")
  ejercicioPersonalizado   EjercicioPersonalizado? @relation(fields: [idEjercicioPersonalizado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sesion_ejercicio_id_ejercicio_personalizado_foreign")
  rutinaEjercicio          RutinaEjercicio?        @relation(fields: [idRutinaEjercicio], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sesion_ejercicio_id_rutina_ejercicio_foreign")
  sesionEntrenamiento      SesionEntrenamiento     @relation(fields: [idSesionEntrenamiento], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sesion_ejercicio_id_sesion_entrenamiento_foreign")
  sesionEjercicioSet       SesionEjercicioSet[]

  @@map("sesion_ejercicio")
  @@schema("app_user")
}

model SesionEjercicioSet {
  id                     BigInt              @id @default(autoincrement()) @map("id")
  idSesionEjercicio      BigInt              @map("id_sesion_ejercicio")
  numeroSet              Int                 @map("numero_set")
  repeticionesObjetivo   Int?                @map("repeticiones_objetivo")
  pesoObjetivo           Decimal?            @map("peso_objetivo") @db.Decimal(10, 2)
  repeticionesRealizadas Int?                @map("repeticiones_realizadas")
  pesoReal               Decimal?            @map("peso_real") @db.Decimal(10, 2)
  rir                    Decimal?            @map("rir") @db.Decimal(4, 2)
  rpe                    Decimal?            @map("rpe") @db.Decimal(4, 2)
  descansoSegundos       Int?                @map("descanso_segundos")
  completado             Boolean             @default(false) @map("completado")
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt              DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  alumnoEjercicioPr      AlumnoEjercicioPr[]
  sesionEjercicio        SesionEjercicio     @relation(fields: [idSesionEjercicio], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sesion_ejercicio_set_id_sesion_ejercicio_foreign")

  @@unique([idSesionEjercicio, numeroSet], map: "sesion_ejercicio_set_unique_numero")
  @@map("sesion_ejercicio_set")
  @@schema("app_user")
}

model AlumnoEjercicioPr {
  id                       BigInt                  @id @default(autoincrement()) @map("id")
  idUsuario                String                  @map("id_usuario") @db.Uuid
  idEjercicioEstandar      BigInt?                 @map("id_ejercicio_estandar")
  idEjercicioPersonalizado BigInt?                 @map("id_ejercicio_personalizado")
  peso                     Decimal                 @map("peso") @db.Decimal(10, 2)
  repeticiones             Int                     @map("repeticiones")
  idSesionEjercicioSet     BigInt                  @map("id_sesion_ejercicio_set")
  fechaPr                  DateTime                @map("fecha_pr") @db.Timestamp(0)
  createdAt                DateTime                @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  ejercicioEstandar        EjercicioEstandar?      @relation(fields: [idEjercicioEstandar], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "alumno_ejercicio_pr_id_ejercicio_estandar_foreign")
  ejercicioPersonalizado   EjercicioPersonalizado? @relation(fields: [idEjercicioPersonalizado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "alumno_ejercicio_pr_id_ejercicio_personalizado_foreign")
  sesionEjercicioSet       SesionEjercicioSet      @relation(fields: [idSesionEjercicioSet], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "alumno_ejercicio_pr_id_sesion_ejercicio_set_foreign")
  usuario                  Usuario                 @relation("usuario_pr", fields: [idUsuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "alumno_ejercicio_pr_id_usuario_foreign")

  @@unique([idUsuario, idEjercicioEstandar, peso], map: "alumno_pr_estandar_peso_unique")
  @@unique([idUsuario, idEjercicioPersonalizado, peso], map: "alumno_pr_personalizado_peso_unique")
  @@map("alumno_ejercicio_pr")
  @@schema("app_user")
}

model AlumnoEntrenadorHistorial {
  id           BigInt     @id @default(autoincrement()) @map("id")
