  objetivo                   String?     @map("objetivo")
  nivelActividad             String?     @map("nivel_actividad")
  observacionesMedicas       String?     @map("observaciones_medicas")
  lesionesActuales           String?     @map("lesiones_actuales")
  lesionesPasadas            String?     @map("lesiones_pasadas")
  contactoEmergenciaNombre   String?     @map("contacto_emergencia_nombre") @db.VarChar(100)
  contactoEmergenciaTelefono String?     @map("contacto_emergencia_telefono") @db.VarChar(30)
  createdAt                  DateTime    @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                  DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  idEntrenadorActual         String?     @map("id_entrenador_actual") @db.Uuid
  createdBy                  String?     @map("created_by") @db.Uuid
  updatedBy                  String?     @map("updated_by") @db.Uuid
  creadoPor                  Usuario?    @relation("usuario_alumno_creado", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "alumno_created_by_foreign")
  entrenadorActual           Entrenador? @relation("alumno_entrenador_actual", fields: [idEntrenadorActual], references: [idUsuario], onDelete: NoAction, onUpdate: NoAction, map: "alumno_id_entrenador_actual_foreign")
  estado                     Estado      @relation("estado_alumno", fields: [idEstado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "alumno_id_estado_foreign")
  usuario                    Usuario     @relation("usuario_alumno", fields: [idUsuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "alumno_id_usuario_foreign")
  actualizadoPor             Usuario?    @relation("usuario_alumno_actualizado", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "alumno_updated_by_foreign")

  @@map("alumno")
  @@schema("alumno")
}

