  gimnasio     Gimnasio   @relation(fields: [idGimnasio], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "entrenador_gimnasio_id_gimnasio_foreign")

  @@map("entrenador_gimnasio")
  @@schema("entrenador")
}

model EntrenadorSeccion {
  id                BigInt      @id @default(autoincrement()) @map("id")
  idEntrenador      String      @map("id_entrenador") @db.Uuid
  idTipoSeccion     BigInt      @map("id_tipo_seccion")
