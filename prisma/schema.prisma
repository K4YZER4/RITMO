}

model EntrenadorTema {
  id              BigInt       @id @default(autoincrement()) @map("id")
  primaryColor    String       @map("primary_color") @db.VarChar(50)
  secundaryColor  String       @map("secundary_color") @db.VarChar(50)
  backgroundColor String       @map("background_color") @db.VarChar(50)
  entrenador      Entrenador[]

  @@map("entrenador_tema")
  @@schema("entrenador")
}

model Entrenador {
  idUsuario                 String                      @id @map("id_usuario") @db.Uuid
  slug                      String                      @map("slug")
  idEstado                  Int                         @default(1) @map("id_estado")
  fechaEntrenador           DateTime                    @map("fecha_entrenador") @db.Date
  idLocalidad               BigInt?                     @map("id_localidad")
  verificacionStatus        Boolean                     @default(false) @map("verificacion_status")
  idTema                    BigInt                      @default(1) @map("id_tema")
  nombrePublico             String?                     @map("nombre_publico") @db.VarChar(50)
  createdAt                 DateTime                    @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                 DateTime                    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  alumnoActual              Alumno[]                    @relation("alumno_entrenador_actual")
  alumnoEntrenadorHistorial AlumnoEntrenadorHistorial[]
  estado                    Estado                      @relation("estado_entrenador", fields: [idEstado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "entrenador_id_estado_foreign")
  localidad                 Localidad?                  @relation(fields: [idLocalidad], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "entrenador_id_localidad_foreign")
  tema                      EntrenadorTema              @relation(fields: [idTema], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "entrenador_id_tema_foreign")
  usuario                   Usuario                     @relation(fields: [idUsuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "entrenador_id_usuario_foreign")
  entrenadorCategorias      EntrenadorCategorias[]
  entrenadorGimnasio        EntrenadorGimnasio[]
  entrenadorRedesSociales   EntrenadorRedesSociales[]
  entrenadorSeccion         EntrenadorSeccion[]

  @@map("entrenador")
  @@schema("entrenador")
}

model EntrenadorRedesSociales {
  id           BigInt        @id @default(autoincrement()) @map("id")
  idEntrenador String        @map("id_entrenador") @db.Uuid
  idRedSocial  Int           @map("id_red_social")
  urlRed       String        @map("url_red")
  entrenador   Entrenador    @relation(fields: [idEntrenador], references: [idUsuario], onDelete: NoAction, onUpdate: NoAction, map: "entrenador_redes_sociales_id_entrenador_foreign")
  redSocial    RedesSociales @relation(fields: [idRedSocial], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "entrenador_redes_sociales_id_red_social_foreign")

  @@unique([idEntrenador, idRedSocial], map: "entrenador_redes_sociales_entrenador_red_unique")
  @@map("entrenador_redes_sociales")
  @@schema("entrenador")
}

model EntrenadorCategorias {
  id           BigInt     @id @default(autoincrement()) @map("id")
  idEntrenador String     @map("id_entrenador") @db.Uuid
  idCategoria  Int        @map("id_categoria")
