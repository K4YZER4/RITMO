  idEntrenador String     @map("id_entrenador") @db.Uuid
  fechaInicio  DateTime   @default(now()) @map("fecha_inicio") @db.Timestamp(0)
  fechaFin     DateTime?  @map("fecha_fin") @db.Timestamp(0)
  activo       Boolean    @default(true) @map("activo")
  motivoCambio String?    @map("motivo_cambio")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  createdBy    String?    @map("created_by") @db.Uuid
  creadoPor    Usuario?   @relation("usuario_historial_creado", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "alumno_entrenador_historial_created_by_foreign")
  entrenador   Entrenador @relation(fields: [idEntrenador], references: [idUsuario], onDelete: NoAction, onUpdate: NoAction, map: "alumno_entrenador_historial_id_entrenador_foreign")
