model Gimnasio {
  id                 BigInt               @id @default(autoincrement()) @map("id")
  nombre             String               @unique @map("nombre") @db.VarChar(100)
  ubicacion          String               @map("ubicacion")
  createdByUsuario   String               @map("created_by_usuario") @db.Uuid
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  idLocalidad        BigInt               @map("id_localidad")
  idEstado           Int                  @map("id_estado")
  entrenadorGimnasio EntrenadorGimnasio[]
  usuario            Usuario              @relation("usuario_gimnasio", fields: [createdByUsuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "gimnasio_created_by_usuario_foreign")
  estado             Estado               @relation("estado_gimnasio", fields: [idEstado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "gimnasio_id_estado_foreign")
  localidad          Localidad            @relation(fields: [idLocalidad], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "gimnasio_id_localidad_foreign")

  @@map("gimnasio")
  @@schema("entrenador")
}

model EntrenadorGimnasio {
  id           BigInt     @id @default(autoincrement()) @map("id")
